{
  "expo": {
    "name": "Timo",
    "slug": "timo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "timo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSCameraUsageDescription": "현장 사진 촬영을 위해 카메라 접근이 필요합니다.",
        "NSLocationWhenInUseUsageDescription": "촬영 사진에 위치 정보를 기록하기 위해 위치 접근이 필요합니다.",
        "NSPhotoLibraryAddUsageDescription": "촬영된 사진을 갤러리에 저장하기 위해 사진 접근이 필요합니다."
      }
    },
    "android": {
      "package": "com.timo.android",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_BINARY_AND_TEXT_RESOURCES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "현장 사진 촬영을 위해 카메라 접근이 필요합니다."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "촬영 사진에 위치 정보를 기록하기 위해 위치 접근이 필요합니다."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "촬영된 사진을 갤러리에 저장하기 위해 사진 접근이 필요합니다.",
          "savePhotosPermission": "촬영된 사진을 갤러리에 저장하기 위해 사진 저장 권한이 필요합니다.",
          "saveAudioPermission": "촬영된 사진을 갤러리에 저장하기 위해 오디오 권한이 필요합니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3d160159-b544-478b-97ca-ba7cebc6e9ce"
      }
    }
  }
}
